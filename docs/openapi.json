{
  "openapi": "3.1.0",
  "info": {
    "title": "Go TDD Server Boilerplate (AI-Ready with MCP)",
    "version": "0.0.2",
    "description": "Professional Go API with TDD, Clean Architecture, MCP (AI Tools) and OIDC/JWKS Security."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Provide a valid JWT token issued by your OIDC provider (e.g., Authentik)."
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Liveness probe",
        "description": "Check if the server is alive. Bypasses authentication.",
        "security": [],
        "responses": {
          "200": { "description": "Server is alive" }
        }
      }
    },
    "/readyz": {
      "get": {
        "summary": "Readiness probe",
        "description": "Check if the server is ready to handle traffic. Bypasses authentication.",
        "security": [],
        "responses": {
          "200": { "description": "Server is ready" }
        }
      }
    },
    "/api/v1/ping": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": { "description": "Returns pong" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/add": {
      "get": {
        "summary": "Sum of two numbers (Exposed via MCP)",
        "parameters": [
          { "name": "a", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "b", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Sum result" },
          "400": { "description": "Invalid input" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/echo": {
      "post": {
        "summary": "Echoes back the message (Exposed via MCP)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "type": "string", "minLength": 1, "maxLength": 100 }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Success response" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/internal": {
      "get": {
        "summary": "Get internal info (Internal API Only)",
        "description": "This endpoint is NOT exposed to AI agents via MCP. Demonstrates internal-only logic.",
        "responses": {
          "200": { "description": "Returns internal data string" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/mcp/sse": {
      "get": {
        "summary": "MCP SSE Endpoint",
        "description": "Entry point for AI agents to connect via Model Context Protocol.",
        "responses": {
          "200": { "description": "SSE Event Stream" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  }
}
