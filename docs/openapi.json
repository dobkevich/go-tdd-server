{
  "openapi": "3.1.0",
  "info": {
    "title": "Go TDD Server Boilerplate (AI-Ready with MCP)",
    "version": "0.0.2",
    "description": "Professional Go API with TDD, Clean Architecture, MCP (AI Tools) and OIDC/JWKS Security."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Provide a valid JWT token issued by your OIDC provider (e.g., via JWKS_URL)."
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "version": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "uptime": { "type": "string" }
        }
      },
      "ReadyResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "version": { "type": "string" }
        }
      },
      "HelloResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "AddResponse": {
        "type": "object",
        "properties": {
          "result": { "type": "integer" }
        }
      },
      "EchoRequest": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "minLength": 1, "maxLength": 100 }
        },
        "required": ["message"]
      },
      "EchoResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Liveness probe",
        "description": "Check if the server is alive. Bypasses authentication. Returns version, status, and uptime.",
        "security": [],
        "responses": {
          "200": { 
            "description": "Server is alive",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } }
          }
        }
      }
    },
    "/readyz": {
      "get": {
        "summary": "Readiness probe",
        "description": "Check if the server is ready to handle traffic. Bypasses authentication.",
        "security": [],
        "responses": {
          "200": { 
            "description": "Server is ready",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReadyResponse" } } }
          }
        }
      }
    },
    "/api/v1/hello/{name}": {
      "get": {
        "summary": "Greeting",
        "parameters": [
          { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { 
            "description": "Greeting message",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HelloResponse" } } }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/add": {
      "get": {
        "summary": "Sum of two numbers (Exposed via MCP)",
        "parameters": [
          { "name": "a", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "b", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { 
            "description": "Sum result",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddResponse" } } }
          },
          "400": { "description": "Invalid input", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/echo": {
      "post": {
        "summary": "Echoes back the message (Exposed via MCP)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/EchoRequest" } }
          }
        },
        "responses": {
          "200": { 
            "description": "Success response",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EchoResponse" } } }
          },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/internal": {
      "get": {
        "summary": "Get internal info (Internal API Only)",
        "description": "This endpoint is NOT exposed to AI agents via MCP. Demonstrates internal-only logic.",
        "responses": {
          "200": { "description": "Returns internal data string" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/mcp/sse": {
      "get": {
        "summary": "MCP SSE Connection",
        "description": "Establish a Server-Sent Events connection for the Model Context Protocol.",
        "responses": {
          "200": { "description": "SSE Event Stream" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "summary": "MCP Messages",
        "description": "Send JSON-RPC messages to the established MCP session.",
        "responses": {
          "202": { "description": "Message accepted" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  }
}
